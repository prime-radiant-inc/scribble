{
  "name": "scribble",
  "version": "1.0.0",
  "type": "module",
  "description": "Self-hosted Slack knowledge bot with wiki, memory, and conversation tools",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prime-radiant-inc/scribble.git"
  },
  "homepage": "https://github.com/prime-radiant-inc/scribble#readme",
  "bugs": {
    "url": "https://github.com/prime-radiant-inc/scribble/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:mcp": "esbuild src/mcp/index.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/mcp.js --external:fsevents --external:simple-git --banner:js='#!/usr/bin/env node'",
    "build:all": "npm run build && npm run build:mcp",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp.js",
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "watch": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "keywords": [
    "slack",
    "claude",
    "bot",
    "knowledge-base"
  ],
  "author": "Prime Radiant",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.217.0",
    "@opentelemetry/instrumentation-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@primeradianthq/bot-toolkit": "^1.0.2",
    "@primeradianthq/streamlinear": "^1.1.3",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.13.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "simple-git": "^3.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5",
    "yaml": "^2.8.4"
  }
}
